# Environment variables template for Next.js frontend
# Copy this file to .env and fill in the actual values

# URL of the backend API (used for server-side API calls)
BACKEND_API_URL=

# Secret for JWT signing (used in API token route)
JWT_SECRET=

# Key ID for JWT signing (optional, used in API token route)
JWT_KEY_ID=

# Public SSE (Server-Sent Events) URL (used in client-side for real-time updates)
NEXT_PUBLIC_SSE_URL=